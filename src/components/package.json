{
  "name": "udi-toolkit",
  "version": "0.0.52",
  "description": "Universal Discovery Interface Toolkit",
  "author": "dev-lan <devinscottlange@gmail.com>",
  "type": "module",
  "private": false,
  "main": "dist/index.cjs",
  "homepage": "https://hms-dbmi.github.io/udi-grammar",
  "module": "dist/index.js",
  "umd": "dist/index.umd.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ce": {
      "types": "./ce.d.ts",
      "import": "./dist/ce.js"
    },
    "./react": {
      "types": "./dist/react-wrapper/index.d.ts",
      "import": "./dist/react.js"
    },
    "./style.css": "./dist/index.css",
    "./dist/index.css": "./dist/index.css",
    "./dist/DataSourcesStore.d.ts": "./dist/DataSourcesStore.d.ts",
    "./dist/GrammarTypes": {
      "types": "./dist/GrammarTypes.d.ts",
      "default": "./dist/GrammarTypes.d.ts"
    },
    "./dist/GrammarTypes.d.ts": "./dist/GrammarTypes.d.ts"
  },
  "files": [
    "dist",
    "ce.d.ts"
  ],
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "npm run build:all && node test/smoke-vue.mjs && node test/smoke-ce.mjs && node test/smoke-react.mjs && node test/smoke-exports.mjs",
    "build": "vite build",
    "build:ce": "vite build --config vite.config.ce.ts",
    "build:react": "vite build --config vite.config.react.ts",
    "build:all": "npm run build && npm run build:ce && npm run build:react",
    "npm-publish": "npm publish --access public"
  },
  "dependencies": {
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "ag-grid-vue3": "^33.2.4",
    "arquero": "^8.0.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "fast-kde": "^0.2.2",
    "lodash": "^4.17.21",
    "vega": "^5.31.0",
    "vega-embed": "^6.29.0",
    "vega-lite": "^5.23.0"
  },
  "peerDependencies": {
    "vue": "^3.4.18",
    "pinia": "^3.0.1",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    },
    "pinia": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@quasar/app-vite": "^2.1.0",
    "@storybook/addon-essentials": "^8.5.8",
    "@storybook/addon-interactions": "^8.5.8",
    "@storybook/addon-onboarding": "^8.5.8",
    "@storybook/blocks": "^8.5.8",
    "@storybook/test": "^8.5.8",
    "@storybook/vue3": "^8.5.8",
    "@storybook/vue3-vite": "^8.5.8",
    "@types/lodash": "^4.17.16",
    "@types/node": "^20.5.9",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.23.0",
    "eslint-plugin-storybook": "^0.11.3",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "vite-plugin-checker": "^0.8.0",
    "vite-plugin-dts": "^4.5.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vue-tsc": "^2.0.29"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hms-dbmi/udi-grammar"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "resolutions": {
    "flatted": "3.4.2",
    "node-forge": "1.4.0",
    "path-to-regexp": "0.1.13",
    "**/anymatch/picomatch": "2.3.2",
    "**/readdirp/picomatch": "2.3.2",
    "**/micromatch/picomatch": "2.3.2",
    "**/@rollup/pluginutils/picomatch": "4.0.4",
    "**/rollup-plugin-visualizer/picomatch": "4.0.4",
    "**/tinyglobby/picomatch": "4.0.4"
  },
  "eslintConfig": {
    "extends": []
  }
}